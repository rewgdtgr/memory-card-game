.container {
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.rank-header {
  text-align: center;
  padding: 40rpx 0;
}

.header-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-summary {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.summary-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.summary-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.summary-content {
  display: flex;
  flex-direction: column;
}

.summary-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #6366f1;
}

.rank-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 24rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #9ca3af;
}

.rank-list {
  display: flex;
  flex-direction: column;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-position {
  width: 60rpx;
  display: flex;
  justify-content: center;
}

.position-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #6b7280;
}

.position-badge.gold {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #ffffff;
}

.position-badge.silver {
  background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%);
  color: #ffffff;
}

.position-badge.bronze {
  background: linear-gradient(135deg, #d97706 0%, #b45309 100%);
  color: #ffffff;
}

.rank-info {
  flex: 1;
  padding: 0 20rpx;
}

.rank-row {
  display: flex;
  justify-content: space-between;
  padding: 6rpx 0;
}

.rank-label {
  font-size: 26rpx;
  color: #9ca3af;
}

.rank-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.rank-score {
  text-align: right;
}

.score-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #f59e0b;
}

.score-unit {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: 4rpx;
}

.tips-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.tips-list {
  padding-left: 10rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}