.container {
  padding: 30rpx;
  padding-bottom: 180rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.hero-section {
  text-align: center;
  padding: 60rpx 0;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  box-shadow: 0 16rpx 40rpx rgba(99, 102, 241, 0.4);
}

.logo-text {
  font-size: 80rpx;
}

.hero-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #6366f1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.game-intro {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.intro-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 24rpx;
  text-align: center;
}

.intro-content {
  padding-left: 20rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rule-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 28rpx;
  color: #374151;
}

.difficulty-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 24rpx;
  text-align: center;
}

.difficulty-grid {
  display: flex;
  justify-content: space-around;
}

.difficulty-item {
  width: 200rpx;
  padding: 24rpx 16rpx;
  background: #f3f4f6;
  border-radius: 20rpx;
  text-align: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  -webkit-transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  -webkit-user-select: none;
  will-change: background, transform;
}

.difficulty-item:active {
  opacity: 0.8;
}

.difficulty-item.active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  transform: scale(1.05);
  -webkit-transform: scale(1.05);
}

.diff-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.diff-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 8rpx;
}

.difficulty-item.active .diff-name {
  color: #ffffff;
}

.diff-desc {
  font-size: 22rpx;
  color: #9ca3af;
}

.difficulty-item.active .diff-desc {
  color: rgba(255, 255, 255, 0.8);
}

.start-btn-wrap {
  padding: 20rpx;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border: none;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(16, 185, 129, 0.4);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  -webkit-transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  -webkit-tap-highlight-color: transparent;
}

.start-btn:active {
  transform: scale(0.98);
  -webkit-transform: scale(0.98);
  opacity: 0.9;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}
